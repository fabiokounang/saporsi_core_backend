<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title %> • Saporsi Core</title>

  <style>
    :root{
      --orange:#ff8a00;
      --orange-soft:#fff2e5;
      --orange-dark:#e36f00;
      --bg:#fff8f1;
      --card:#ffffff;
      --text:#1f2937;
      --muted:#6b7280;
      --border:#e5e7eb;
      --danger:#ef4444;
      --radius:18px;
      --shadow:0 20px 45px rgba(0,0,0,.08);
      --font: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
    }

    *{box-sizing:border-box}
    html,body{height:100%}

    body{
      margin:0;
      font-family:var(--font);
      background:
        radial-gradient(900px 500px at 10% 10%, #ffe0bf, transparent 60%),
        radial-gradient(700px 500px at 90% 20%, #ffd1a3, transparent 55%),
        var(--bg);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
      color:var(--text);
    }

    .wrap{
      width:min(980px,100%);
      display:grid;
      grid-template-columns:1.1fr .9fr;
      gap:32px;
      align-items:stretch;
    }

    @media(max-width:900px){
      .wrap{grid-template-columns:1fr; max-width:520px;}
    }

    /* LEFT */
    .brand{
      background:linear-gradient(160deg,#ffb866,#ff8a00);
      color:white;
      border-radius:var(--radius);
      padding:36px;
      box-shadow:var(--shadow);
      position:relative;
      overflow:hidden;
    }

    .brand::after{
      content:"";
      position:absolute;
      width:420px;height:420px;
      right:-180px;bottom:-220px;
      background:radial-gradient(circle,#ffffff55,transparent 60%);
    }

    .logo{
      display:flex;
      align-items:center;
      gap:12px;
      font-weight:800;
      font-size:18px;
    }

    .logoBox{
      width:44px;height:44px;
      background:white;
      color:var(--orange-dark);
      border-radius:14px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:900;
      box-shadow:0 10px 25px rgba(0,0,0,.15);
    }

    .hero{
      margin-top:28px;
      position:relative;
      z-index:1;
    }

    .hero h1{
      margin:0 0 12px;
      font-size:36px;
      line-height:1.15;
    }

    .hero p{
      margin:0;
      font-size:15px;
      line-height:1.6;
      opacity:.95;
      max-width:52ch;
    }

    .points{
      margin-top:26px;
      display:grid;
      gap:14px;
      position:relative;
      z-index:1;
    }

    .point{
      background:rgba(255,255,255,.18);
      border-radius:14px;
      padding:14px 16px;
      backdrop-filter: blur(6px);
    }

    .point b{
      display:block;
      font-size:14px;
      margin-bottom:4px;
    }

    .point small{
      font-size:13px;
      opacity:.95;
      line-height:1.45;
    }

    /* RIGHT CARD */
    .card{
      background:var(--card);
      border-radius:var(--radius);
      padding:28px;
      box-shadow:var(--shadow);
      border:1px solid var(--border);
    }

    .card h2{
      margin:0 0 6px;
      font-size:20px;
    }

    .sub{
      font-size:13px;
      color:var(--muted);
      margin-bottom:18px;
    }

    .alert{
      background:#fee2e2;
      border:1px solid #fecaca;
      color:#991b1b;
      padding:12px 14px;
      border-radius:14px;
      font-size:13px;
      margin-bottom:14px;
    }

    label{
      font-size:13px;
      display:block;
      margin-bottom:6px;
      color:#374151;
    }

    .field{margin-bottom:14px;}

    input{
      width:100%;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid var(--border);
      font-size:14px;
      outline:none;
      transition:.15s;
      background:white;
    }

    input:focus{
      border-color:var(--orange);
      box-shadow:0 0 0 4px #ff8a0026;
    }

    .row{
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin:6px 0 18px;
      font-size:12.5px;
      color:var(--muted);
    }

    .link{
      color:var(--orange-dark);
      text-decoration:none;
      font-weight:600;
    }

    .link:hover{text-decoration:underline;}

    .btn{
      width:100%;
      padding:13px;
      border-radius:14px;
      border:none;
      cursor:pointer;
      font-weight:700;
      font-size:14px;
      background:linear-gradient(135deg,var(--orange),#ffb347);
      color:white;
      box-shadow:0 14px 30px rgba(255,138,0,.35);
      transition:.15s;
    }

    .btn:hover{transform:translateY(-1px);}
    .btn:active{transform:translateY(0);}

    .foot{
      margin-top:16px;
      text-align:center;
      font-size:12px;
      color:var(--muted);
      line-height:1.5;
    }
  </style>
</head>

<body>
  <main class="wrap">
    <!-- LEFT -->
    <section class="brand">
      <div class="logo">
        <div class="logoBox">S</div>
        Saporsi Core
      </div>

      <div class="hero">
        <h1>Welcome back 👋</h1>
        <p>
          Login ke sistem operasional Saporsi untuk mengelola vending,
          transaksi, dan laporan merchant secara rapi & transparan.
        </p>
      </div>

      <div class="points">
        <div class="point">
          <b>💳 Pembayaran Aman</b>
          <small>Setiap transaksi tercatat dan bisa diaudit.</small>
        </div>
        <div class="point">
          <b>📦 Operasional Jelas</b>
          <small>Barang keluar sesuai pembayaran, tanpa ribet.</small>
        </div>
        <div class="point">
          <b>🤝 Siap untuk Klien</b>
          <small>Tampilan profesional yang bikin merchant percaya.</small>
        </div>
      </div>
    </section>

    <!-- RIGHT -->
    <section class="card">
      <h2>Sign in</h2>
      <div class="sub">Gunakan akun yang sudah terdaftar</div>

      <% if (error) { %>
        <div class="alert"><%= error %></div>
      <% } %>

      <form method="POST" action="/auth/login">
        <div class="field">
          <label>Email / Username</label>
          <input
            name="identifier"
            placeholder="admin@saporsi.local"
            value="<%= value && value.identifier ? value.identifier : '' %>"
            required
          />
        </div>

        <div class="field">
          <label>Password</label>
          <input
            type="password"
            name="password"
            placeholder="••••••••"
            required
          />
        </div>

        <div class="row">
          <span>Tekan Enter untuk login</span>
          <a class="link" href="javascript:void(0)">Lupa password?</a>
        </div>

        <button class="btn" type="submit">Login</button>

        <div class="foot">
          Saporsi Core © <%= new Date().getFullYear() %><br/>
          Reliable vending operations
        </div>
      </form>
    </section>
  </main>
</body>
</html>
