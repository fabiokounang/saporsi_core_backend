<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title || "Not Found" %></title>

  <style>
    :root{
      --orange:#ff8a00;--orange2:#ffb866;
      --bg:#fff8f1;--card:#fff;--text:#111827;--muted:#6b7280;--border:#e5e7eb;
      --shadow:0 18px 45px rgba(0,0,0,.08);--radius:18px;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;
      background:
        radial-gradient(900px 500px at 10% 10%, #ffe0bf, transparent 60%),
        radial-gradient(700px 500px at 90% 20%, #ffd1a3, transparent 55%),
        var(--bg);
      color:var(--text);
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:22px;
    }
    .card{
      width:min(820px,100%);
      background:var(--card);
      border:1px solid var(--border);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      overflow:hidden;
    }
    .top{
      background:linear-gradient(135deg,var(--orange),var(--orange2));
      color:#fff;
      padding:18px 20px;
      font-weight:900;
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      flex-wrap:wrap;
    }
    .badge{
      background:rgba(255,255,255,.25);
      border:1px solid rgba(255,255,255,.35);
      padding:6px 10px;
      border-radius:999px;
      font-size:12px;
      font-weight:900;
    }
    .content{padding:22px;}
    h1{margin:0 0 6px;font-size:28px;letter-spacing:-.02em;}
    p{margin:0;color:var(--muted);line-height:1.6;}
    .actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px;}
    .btn{
      display:inline-flex;align-items:center;justify-content:center;gap:8px;
      padding:11px 14px;border-radius:12px;font-weight:900;font-size:13px;
      border:1px solid transparent;text-decoration:none;cursor:pointer;
      transition:.15s ease;
      user-select:none;
    }
    .btn-primary{
      background:linear-gradient(135deg,var(--orange),var(--orange2));
      color:#fff;
      box-shadow:0 14px 28px rgba(255,138,0,.28);
    }
    .btn-secondary{
      background:#fff;border-color:var(--border);color:#7c2d12;
    }
    .btn-secondary:hover{background:#fff7ed}
    .hint{
      margin-top:14px;
      font-size:12.5px;
      color:var(--muted);
      background:#fffaf4;
      border:1px dashed #f1caa2;
      padding:12px 12px;
      border-radius:14px;
    }
    code{
      font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size:12.5px;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="top">
      <div>Saporsi Core</div>
      <div class="badge">404 • Not Found</div>
    </div>

    <div class="content">
      <h1>Halaman tidak ditemukan</h1>
      <p>Link yang kamu akses tidak ada, atau sudah dipindahkan.</p>

      <div class="actions">
        <a class="btn btn-secondary" href="/auth/login">Login</a>
      </div>

      <% if (typeof path !== "undefined" && path) { %>
        <div class="hint">Requested path: <code><%= path %></code></div>
      <% } %>
    </div>
  </div>
</body>
</html>
