<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Generate QRIS</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      background: linear-gradient(135deg, #f8fafc, #eef2ff);
      min-height: 100vh;
      color: #1e293b;
    }

    .page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .card {
      width: 100%;
      max-width: 980px;
      background: #ffffff;
      border-radius: 24px;
      box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
      overflow: hidden;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .left,
    .right {
      padding: 32px;
    }

    .left {
      background: linear-gradient(180deg, #ffffff, #f8fafc);
      border-right: 1px solid #e2e8f0;
    }

    .badge {
      display: inline-block;
      background: #e0e7ff;
      color: #4338ca;
      font-size: 12px;
      font-weight: 700;
      padding: 8px 12px;
      border-radius: 999px;
      margin-bottom: 16px;
    }

    h1 {
      font-size: 30px;
      line-height: 1.2;
      margin-bottom: 10px;
      color: #0f172a;
    }

    .desc {
      font-size: 14px;
      line-height: 1.7;
      color: #64748b;
      margin-bottom: 28px;
    }

    .form-group {
      margin-bottom: 18px;
    }

    label {
      display: block;
      margin-bottom: 8px;
      font-size: 14px;
      font-weight: 600;
      color: #334155;
    }

    input,
    textarea,
    select {
      width: 100%;
      border: 1px solid #cbd5e1;
      border-radius: 14px;
      padding: 14px 16px;
      font-size: 14px;
      outline: none;
      transition: 0.2s ease;
      background: #fff;
    }

    input:focus,
    textarea:focus,
    select:focus {
      border-color: #6366f1;
      box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
    }

    textarea {
      min-height: 100px;
      resize: vertical;
    }

    .btn {
      width: 100%;
      border: none;
      background: #4f46e5;
      color: #fff;
      font-size: 15px;
      font-weight: 700;
      padding: 14px 18px;
      border-radius: 14px;
      cursor: pointer;
      transition: 0.2s ease;
    }

    .btn:hover {
      background: #4338ca;
      transform: translateY(-1px);
    }

    .helper {
      margin-top: 12px;
      font-size: 12px;
      color: #94a3b8;
      text-align: center;
    }

    .right {
      display: flex;
      flex-direction: column;
      justify-content: center;
      background: #f8fafc;
    }

    .preview-box {
      background: #ffffff;
      border: 1px dashed #cbd5e1;
      border-radius: 20px;
      padding: 24px;
      text-align: center;
      min-height: 420px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    .preview-box h2 {
      font-size: 22px;
      margin-bottom: 12px;
      color: #0f172a;
    }

    .preview-box p {
      font-size: 14px;
      color: #64748b;
      line-height: 1.7;
      margin-bottom: 20px;
    }

    .qris-image {
      width: 100%;
      max-width: 260px;
      border-radius: 16px;
      box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
      margin-bottom: 16px;
    }

    .qris-string {
      width: 100%;
      text-align: left;
      background: #0f172a;
      color: #e2e8f0;
      font-size: 12px;
      line-height: 1.6;
      padding: 14px;
      border-radius: 14px;
      word-break: break-all;
      margin-top: 12px;
    }

    .meta {
      width: 100%;
      margin-top: 16px;
      text-align: left;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 16px;
      padding: 14px 16px;
    }

    .meta-item {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      font-size: 14px;
      padding: 8px 0;
      border-bottom: 1px solid #e2e8f0;
    }

    .meta-item:last-child {
      border-bottom: none;
    }

    .meta-label {
      color: #64748b;
    }

    .meta-value {
      color: #0f172a;
      font-weight: 600;
      text-align: right;
    }

    .alert {
      margin-bottom: 18px;
      padding: 12px 14px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 600;
    }

    .alert-error {
      background: #fef2f2;
      color: #b91c1c;
      border: 1px solid #fecaca;
    }

    .alert-success {
      background: #ecfdf5;
      color: #047857;
      border: 1px solid #a7f3d0;
    }

    @media (max-width: 860px) {
      .card {
        grid-template-columns: 1fr;
      }

      .left {
        border-right: none;
        border-bottom: 1px solid #e2e8f0;
      }

      h1 {
        font-size: 26px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="card">
      <div class="left">
        <div class="badge">QRIS Payment</div>
        <h1>Generate QRIS</h1>
        <p class="desc">
          Buat QRIS pembayaran dengan cepat dan rapi. Isi data yang dibutuhkan,
          lalu sistem akan generate QRIS dari API yang sudah kamu siapkan.
        </p>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <% if (typeof success !== 'undefined' && success) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>

        <form action="/orders/create-qris" method="POST">
          <div class="form-group">
            <label for="machine_id">Machine ID</label>
            <input
              type="number"
              id="machine_id"
              name="machine_id"
              placeholder="Contoh: 1"
              min="1"
              required
              value="<%= old?.machine_id || '' %>"
            />
          </div>

          <div class="form-group">
            <label for="slot_id">Slot ID</label>
            <input
              type="number"
              id="slot_id"
              name="slot_id"
              placeholder="Contoh: 1"
              min="1"
              required
              value="<%= old?.slot_id || '' %>"
            />
          </div>

          <div class="form-group">
            <label for="qty">Qty</label>
            <input
              type="number"
              id="qty"
              name="qty"
              placeholder="Contoh: 1"
              min="1"
              required
              value="<%= old?.qty || 1 %>"
            />
          </div>

          <!-- <div class="form-group">
            <label for="reference">Reference / Order ID</label>
            <input
              type="text"
              id="reference"
              name="reference"
              placeholder="Contoh: INV-20260331-001"
              value="<%= old?.reference || '' %>"
            />
          </div> -->

          <!-- <div class="form-group">
            <label for="note">Note</label>
            <textarea
              id="note"
              name="note"
              placeholder="Catatan tambahan jika diperlukan"
            ><%= old?.note || '' %></textarea>
          </div> -->

          <button type="submit" class="btn">Generate QRIS</button>
          <div class="helper">Simple, clean, dan siap dihubungkan ke API kamu</div>
        </form>
      </div>

      <div class="right">
        <div class="preview-box">
          <% if (typeof result !== 'undefined' && result) { %>
            <% if (result.qr_image_url) { %>
              <!-- <img
                src="<%= result.url %>"
                alt="QRIS"
                class="qris-image"
              /> -->
            <% } %>


            <!-- <% if (result.qr_image_base64) { %>
              <img
                src="data:image/png;base64,<%= result.qr_image_base64 %>"
                alt="QRIS"
                class="qris-image"
              />
            <% } %> -->

            <div class="meta">
              <div class="meta-item">
                <div class="meta-label">Amount</div>
                <div class="meta-value">
                  Rp <%= Number(result.gross_amount || 0).toLocaleString('id-ID') %>
                </div>
              </div>

              <!-- <div class="meta-item">
                <div class="meta-label">Customer</div>
                <div class="meta-value"><%= result.customer_name || old?.customer_name || '-' %></div>
              </div> -->

              <div class="meta-item">
                <div class="meta-label">Reference</div>
                <div class="meta-value"><%= result.transaction_id || old?.transaction_id || '-' %></div>
              </div>

              <div class="meta-item">
                <div class="meta-label">Expired At</div>
                <div class="meta-value"><%= result.expires_at || '-' %></div>
              </div>
            </div>

            <% if (result.qr_image_url) { %>
              <div class="qris-string"><%= result.qr_image_url %></div>
            <% } %>
          <% } else { %>
            <h2>Preview Area</h2>
            <p>
              Hasil QRIS akan muncul di sini setelah form di-submit.
              Bisa menampilkan gambar QRIS, nominal, reference, dan data raw QR string.
            </p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>