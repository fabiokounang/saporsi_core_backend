<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title %></title>

  <style>
    :root{
      --bg:#fff8f1;--card:#fff;--text:#111827;--muted:#6b7280;--border:#e5e7eb;
      --orange:#ff8a00;--orange2:#ffb866;--shadow:0 18px 45px rgba(0,0,0,.08);--radius:16px;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;
      background: #fff6ec;
      color:var(--text);
    }
    .topbar{
      background:linear-gradient(135deg,var(--orange),var(--orange2));
      color:#fff;
      padding:16px 22px;
      font-weight:900;
    }
    .wrap{max-width:1100px;margin:0 auto;padding:22px;}
    .header{
      display:flex;justify-content:space-between;align-items:flex-start;gap:14px;
      margin-bottom:14px;
    }
    h1{margin:0;font-size:22px}
    .meta{color:var(--muted);font-size:13px;margin-top:8px}
    .actions{display:flex;gap:10px;flex-wrap:wrap;align-items:center;}
    a{color:inherit;text-decoration:none}
    .btn{
      display:inline-flex;align-items:center;justify-content:center;gap:8px;
      padding:10px 12px;border-radius:12px;font-weight:900;font-size:13px;
      border:1px solid transparent;cursor:pointer;transition:.15s ease;
    }
    .btn-primary{
      background:linear-gradient(135deg,var(--orange),var(--orange2));
      color:#fff;box-shadow:0 14px 28px rgba(255,138,0,.28);
    }
    .btn-ghost{
      background:rgba(255,255,255,.75);
      border-color:rgba(255,255,255,.6);
      color:#7c2d12;
    }
    .btn-ghost:hover{background:#fff}
    .btn-link{background:transparent;border-color:transparent;color:#7c2d12;padding:10px 6px}
    .btn-link:hover{text-decoration:underline}

    .card{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      overflow:hidden;
    }
    .toolbar{
      display:flex;justify-content:space-between;align-items:center;gap:12px;
      padding:14px 16px;border-bottom:1px solid #f1f5f9;
      background:linear-gradient(180deg,#fff, #fffaf4);
    }
    .pill{
      display:inline-flex;align-items:center;gap:8px;
      padding:6px 10px;border-radius:999px;border:1px solid var(--border);
      background:#fff;color:#374151;font-weight:900;font-size:12px;
    }
    .pill small{color:var(--muted);font-weight:800}

    table{width:100%;border-collapse:collapse}
    thead th{
      position:sticky;top:0;z-index:1;
      text-align:left;
      font-size:12px;
      text-transform:uppercase;
      letter-spacing:.08em;
      color:#7c2d12;
      background:#fff2e5;
      border-bottom:1px solid #f1caa2;
      padding:12px 14px;
    }
    tbody td{
      padding:12px 14px;border-bottom:1px solid #f1f5f9;font-size:14px;vertical-align:top;
    }
    tbody tr:nth-child(2n){background:#fffdf9}
    tbody tr:hover{background:#fff4e6}
    .mono{font-variant-numeric:tabular-nums}
    .muted{color:var(--muted);font-size:13px}
    .badge{
      display:inline-flex;align-items:center;gap:6px;
      padding:5px 10px;border-radius:999px;font-size:12px;font-weight:900;border:1px solid var(--border);
    }
    .dot{width:8px;height:8px;border-radius:999px}
    .on{background:#ecfdf5;color:#065f46;border-color:#bbf7d0}
    .on .dot{background:#10b981}
    .off{background:#fef2f2;color:#991b1b;border-color:#fecaca}
    .off .dot{background:#ef4444}
    .empty{padding:26px 16px;color:var(--muted);text-align:center;}
    .footer{
      display:flex;justify-content:space-between;align-items:center;gap:12px;
      padding:14px 16px;background:linear-gradient(180deg,#fffaf4,#fff);
    }
    .pager{display:flex;gap:10px;align-items:center;flex-wrap:wrap;justify-content:flex-end;}
    .select{
      padding:9px 10px;border-radius:12px;border:1px solid var(--border);
      background:#fff;font-weight:900;font-size:13px;color:#374151;outline:none;
    }
    .select:focus{border-color:var(--orange);box-shadow:0 0 0 4px rgba(255,138,0,.16)}
    .loc-banner{margin-bottom:14px;padding:12px 14px;border-radius:12px;background:#fef2f2;border:1px solid #fecaca;color:#991b1b;font-size:14px;}
    .modal-overlay{
      position:fixed;inset:0;background:rgba(17,24,39,.5);z-index:100000;
      display:none;align-items:center;justify-content:center;padding:20px;
      backdrop-filter:blur(3px);
    }
    .modal-overlay.is-open{display:flex;}
    .modal-box{
      background:#fff;border-radius:16px;max-width:440px;width:100%;
      padding:22px 24px;box-shadow:0 24px 50px rgba(0,0,0,.18);
      border:1px solid var(--border);
    }
    .modal-box h2{margin:0 0 10px;font-size:18px;color:#991b1b;}
    .modal-box p{margin:0 0 8px;font-size:14px;line-height:1.55;color:#374151;}
    .modal-note{font-size:13px;color:var(--muted);margin-bottom:18px;}
    .modal-actions{display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap;margin-top:8px;}
    .btn-modal-danger{background:#b91c1c;color:#fff;border:0;padding:10px 14px;border-radius:12px;font-weight:800;cursor:pointer;font:inherit;}
    .btn-modal-cancel{background:#fff;border:1px solid var(--border);color:#374151;padding:10px 14px;border-radius:12px;font-weight:800;cursor:pointer;font:inherit;}
  </style>
</head>
<body>
  <% const archQs = (typeof archivedOnly !== 'undefined' && archivedOnly) ? '&archived=1' : ''; %>
  <div class="topbar">Saporsi Admin • Locations</div>

  <div class="wrap">
    <% if (typeof queryError !== 'undefined' && queryError) { %>
      <div class="loc-banner"><b>Perhatian:</b> <%= queryError %></div>
    <% } %>

    <div class="header">
      <div>
        <h1><%= (typeof archivedOnly !== 'undefined' && archivedOnly) ? 'Lokasi master (arsip)' : 'Lokasi master' %></h1>
        <div class="meta">Hanya lokasi induk. Sub-lokasi lewat menu <b>Detail</b>. Total: <b><%= total %></b> • Hal. <b><%= page %></b>/<b><%= totalPages %></b></div>
      </div>
      <div class="actions">
        <% if (typeof archivedOnly !== 'undefined' && archivedOnly) { %>
          <a class="btn btn-ghost" href="/admin/locations">Lokasi aktif</a>
        <% } else { %>
          <a class="btn btn-ghost" href="/admin/locations?archived=1">Arsip</a>
        <% } %>
        <a class="btn btn-primary" href="/admin/locations/new">+ Lokasi master</a>
        <a class="btn btn-ghost" href="/admin">Dashboard</a>
        <a class="btn btn-link" href="/auth/logout">Logout</a>
      </div>
    </div>

    <div class="card">
      <div class="toolbar">
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
          <span class="pill">Showing <small><%= rows ? rows.length : 0 %></small> items</span>
          <span class="pill">Limit <small><%= limit %></small></span>
        </div>
        <div class="muted">
          <% if (typeof archivedOnly !== 'undefined' && archivedOnly) { %>
            Lokasi diarsipkan tidak muncul di pilihan mesin.
          <% } else { %>
            Tambah sub dari halaman <b>Detail</b> master. Hapus master hanya jika tidak ada sub aktif &amp; tidak ada mesin.
          <% } %>
        </div>
      </div>

      <% if (!rows || rows.length === 0) { %>
        <div class="empty">Belum ada lokasi master. Klik <b>+ Lokasi master</b> untuk menambahkan.</div>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th style="width:72px;">ID</th>
              <th>Nama</th>
              <th>Alamat / catatan</th>
              <th style="width:120px;">Status</th>
              <th style="width:240px;">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach(function(l){
                 const locDelLabel = (l.name || '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;');
            %>
              <tr>
                <td class="mono"><%= l.id %></td>
                <td><b><%= l.name %></b><div class="muted mono" style="margin-top:4px;">Updated: <%= l.updated_at %></div></td>
                <td class="muted"><%= l.address || '—' %><% if (l.notes) { %><div style="margin-top:6px;"><b>Catatan:</b> <%= l.notes %></div><% } %></td>
                <td>
                  <% if (l.is_active) { %>
                    <span class="badge on"><span class="dot"></span> Aktif</span>
                  <% } else { %>
                    <span class="badge off"><span class="dot"></span> Nonaktif</span>
                  <% } %>
                </td>
                <td style="white-space:nowrap;">
                  <a class="btn btn-primary" style="padding:8px 10px;" href="/admin/locations/<%= l.id %>">Detail</a>
                  <a class="btn btn-ghost" style="padding:8px 10px;" href="/admin/locations/<%= l.id %>/edit">Edit</a>
                  <% if (!(typeof archivedOnly !== 'undefined' && archivedOnly)) { %>
                    <form class="js-soft-delete-form" method="POST" action="/admin/locations/<%= l.id %>/soft-delete" style="display:inline;">
                      <button type="button" class="btn btn-ghost js-open-soft-delete" style="padding:8px 10px;color:#b91c1c;border-color:#fecaca;"
                        data-delete-label="<%= locDelLabel %>">Hapus</button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>

      <div class="footer">
        <div class="muted">
          <% const start = (page - 1) * limit + 1; %>
          <% const end = (page - 1) * limit + (rows ? rows.length : 0); %>
          <% if (rows && rows.length) { %>
            Showing <b><%= start %></b>–<b><%= end %></b> of <b><%= total %></b>
          <% } else { %>
            Showing 0 of <b><%= total %></b>
          <% } %>
        </div>

        <div class="pager">
          <label class="muted">Limit</label>
          <select class="select" onchange="location.href='/admin/locations?page=1&limit=' + this.value + '<%= archQs %>';">
            <option value="10" <%= limit === 10 ? 'selected' : '' %>>10</option>
            <option value="20" <%= limit === 20 ? 'selected' : '' %>>20</option>
            <option value="50" <%= limit === 50 ? 'selected' : '' %>>50</option>
          </select>

          <% const prev = page > 1 ? page - 1 : 1; %>
          <% const next = page < totalPages ? page + 1 : totalPages; %>

          <% if (page > 1) { %>
            <a class="btn btn-primary" href="/admin/locations?page=<%= prev %>&limit=<%= limit %><%= archQs %>">Prev</a>
          <% } %>
          <% if (page < totalPages) { %>
            <a class="btn btn-primary" href="/admin/locations?page=<%= next %>&limit=<%= limit %><%= archQs %>">Next</a>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div id="soft-delete-modal" class="modal-overlay" role="presentation" aria-hidden="true">
    <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="sdm-title">
      <h2 id="sdm-title">Arsipkan lokasi?</h2>
      <p>Lokasi berikut akan diarsipkan (soft delete):</p>
      <p id="sdm-merchant" style="font-weight:800;color:#111827;"></p>
      <p class="modal-note">Lokasi tidak lagi muncul di pilihan mesin. Data order/mesin yang sudah mereferensi ID ini tetap aman di database.</p>
      <div class="modal-actions">
        <button type="button" class="btn-modal-cancel" id="sdm-cancel">Batal</button>
        <button type="button" class="btn-modal-danger" id="sdm-confirm">Ya, arsipkan</button>
      </div>
    </div>
  </div>
  <script src="/public/js/admin-merchant-soft-delete.js" defer></script>
</body>
</html>
