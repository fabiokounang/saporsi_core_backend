<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title %></title>
  <style>
    :root{
      --bg:#fff8f1;--card:#fff;--text:#111827;--muted:#6b7280;--border:#e5e7eb;
      --orange:#ff8a00;--orange2:#ffb866;--shadow:0 18px 45px rgba(0,0,0,.08);--radius:16px;
      --danger-bg:#fef2f2;--danger-border:#fecaca;--danger-text:#991b1b;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;background:var(--bg);color:var(--text);}
    .topbar{background:linear-gradient(135deg,var(--orange),var(--orange2));color:#fff;padding:16px 22px;font-weight:900;}
    .wrap{max-width:760px;margin:0 auto;padding:22px;}
    .card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);padding:18px;}
    h1{margin:0 0 10px;font-size:22px}
    .muted{color:var(--muted);font-size:13px}
    label{display:block;margin:14px 0 6px;font-weight:900;font-size:13px;color:#374151}
    input,select,textarea{
      width:100%;padding:12px 14px;border:1px solid var(--border);border-radius:12px;
      font-size:14px;outline:none;background:#fff;
    }
    textarea{min-height:90px;resize:vertical}
    input:focus,select:focus,textarea:focus{border-color:var(--orange);box-shadow:0 0 0 4px rgba(255,138,0,.16)}
    .row{display:flex;gap:12px;flex-wrap:wrap;margin-top:16px;align-items:center;}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;
      padding:11px 14px;border-radius:12px;font-weight:900;font-size:13px;border:1px solid transparent;cursor:pointer;text-decoration:none}
    .btn-primary{background:linear-gradient(135deg,var(--orange),var(--orange2));color:#fff;box-shadow:0 14px 28px rgba(255,138,0,.28)}
    .btn-secondary{background:#fff;border-color:var(--border);color:#7c2d12}
    .btn-secondary:hover{background:#fff7ed}
    .alert{background:var(--danger-bg);border:1px solid var(--danger-border);color:var(--danger-text);
      padding:12px 12px;border-radius:12px;margin-bottom:12px;font-size:13px}
    .hint{margin-top:6px;color:var(--muted);font-size:12.5px}
    .master-banner{background:#eff6ff;border:1px solid #bfdbfe;color:#1e40af;padding:12px 14px;border-radius:12px;margin-bottom:14px;font-size:14px;}
  </style>
</head>
<body>
  <div class="topbar">Saporsi Admin • <%= typeof isSubFlow !== 'undefined' && isSubFlow ? 'Sub-lokasi' : 'Lokasi master' %></div>

  <div class="wrap">
    <h1><%= typeof isSubFlow !== 'undefined' && isSubFlow ? 'Tambah sub-lokasi' : 'Tambah lokasi master' %></h1>
    <div class="muted">
      <% if (typeof isSubFlow !== 'undefined' && isSubFlow && presetMasterName) { %>
        Sub di bawah master: <b><%= presetMasterName %></b>. Isi nama (mis. Terminal 1A).
      <% } else { %>
        Di sini hanya untuk <b>lokasi master</b> (bandara / kawasan). Sub-lokasi ditambah dari halaman <b>Detail</b> master.
      <% } %>
    </div>

    <div style="height:14px;"></div>

    <% if (typeof isSubFlow !== 'undefined' && isSubFlow && value?.parent_id) { %>
      <div class="master-banner">
        Induk tetap: <b><%= presetMasterName || ('ID ' + value.parent_id) %></b> — tidak bisa diubah di form ini.
      </div>
    <% } %>

    <div class="card">
      <% if (error) { %>
        <div class="alert"><b>Gagal:</b> <%= error %></div>
      <% } %>

      <form method="POST" action="/admin/locations">
        <% if (typeof isSubFlow !== 'undefined' && isSubFlow) { %>
          <input type="hidden" name="sub_flow" value="1" />
          <input type="hidden" name="parent_id" value="<%= value?.parent_id || '' %>" />
        <% } %>

        <% if (!(typeof isSubFlow !== 'undefined' && isSubFlow)) { %>
          <p class="muted" style="margin:0 0 8px;font-size:14px;">Tidak ada pemilihan induk — ini selalu lokasi master baru.</p>
        <% } %>

        <label for="name">Nama lokasi</label>
        <input id="name" name="name" value="<%= value?.name || '' %>" placeholder="<%= (typeof isSubFlow !== 'undefined' && isSubFlow) ? 'mis. Terminal 1A' : 'mis. Bandara Soekarno-Hatta' %>" required />
        <div class="hint">Nama unik per level: tidak boleh sama dengan lokasi lain di bawah induk yang sama.</div>

        <label for="address">Alamat (opsional)</label>
        <input id="address" name="address" value="<%= value?.address || '' %>" placeholder="Detail alamat / area" />

        <label for="notes">Catatan (opsional)</label>
        <textarea id="notes" name="notes" placeholder="Akses, izin security, dll."><%= value?.notes || '' %></textarea>

        <label for="is_active">Status</label>
        <select id="is_active" name="is_active">
          <option value="1" <%= (value?.is_active ?? 1) ? 'selected' : '' %>>Aktif</option>
          <option value="0" <%= (value?.is_active ?? 1) ? '' : 'selected' %>>Nonaktif</option>
        </select>

        <div class="row">
          <button class="btn btn-primary" type="submit">Simpan</button>
          <% const cancelHref = (typeof isSubFlow !== 'undefined' && isSubFlow && value?.parent_id) ? ('/admin/locations/' + value.parent_id) : '/admin/locations'; %>
          <a class="btn btn-secondary" href="<%= cancelHref %>">Batal</a>
          <a class="btn btn-secondary" href="/admin">Dashboard</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
