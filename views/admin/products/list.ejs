<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title %></title>
  <style>
    :root{
      --bg:#fff6ec;--card:#fff;--text:#111827;--muted:#6b7280;--border:#e5e7eb;
      --orange:#ff8a00;--orange2:#ffb866;--shadow:0 18px 45px rgba(0,0,0,.08);--radius:16px;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;background:var(--bg);color:var(--text);}
    .topbar{background:linear-gradient(135deg,var(--orange),var(--orange2));color:#fff;padding:16px 22px;font-weight:900;}
    .wrap{max-width:1100px;margin:0 auto;padding:22px;}
    .header{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;margin-bottom:14px;}
    h1{margin:0;font-size:22px}
    .meta{color:var(--muted);font-size:13px;margin-top:8px}
    .actions{display:flex;gap:10px;flex-wrap:wrap;align-items:center;}
    a{color:inherit;text-decoration:none}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 12px;border-radius:12px;font-weight:900;font-size:13px;border:1px solid transparent;transition:.15s ease;}
    .btn-primary{background:linear-gradient(135deg,var(--orange),var(--orange2));color:#fff;box-shadow:0 14px 28px rgba(255,138,0,.28)}
    .btn-ghost{background:#fff;border-color:var(--border);color:#7c2d12}
    .btn-ghost:hover{background:#fff7ed}
    .btn-link{background:transparent;border-color:transparent;color:#7c2d12;padding:10px 6px}
    .btn-link:hover{text-decoration:underline}
    .card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;}
    .toolbar{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:14px 16px;border-bottom:1px solid #f1f5f9;background:#fff;}
    table{width:100%;border-collapse:collapse}
    thead th{position:sticky;top:0;z-index:1;text-align:left;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:#7c2d12;background:#fff2e5;border-bottom:1px solid #f1caa2;padding:12px 14px;}
    tbody td{padding:12px 14px;border-bottom:1px solid #f1f5f9;font-size:14px;vertical-align:middle;}
    tbody tr:nth-child(2n){background:#fffdf9}
    tbody tr:hover{background:#fff4e6}
    .mono{font-variant-numeric:tabular-nums}
    .muted{color:var(--muted);font-size:13px}
    .badge{display:inline-flex;align-items:center;gap:6px;padding:5px 10px;border-radius:999px;font-size:12px;font-weight:900;border:1px solid var(--border);}
    .dot{width:8px;height:8px;border-radius:999px}
    .on{background:#ecfdf5;color:#065f46;border-color:#bbf7d0}.on .dot{background:#10b981}
    .off{background:#fef2f2;color:#991b1b;border-color:#fecaca}.off .dot{background:#ef4444}
    .footer{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:14px 16px;background:#fff;}
    .pager{display:flex;gap:10px;align-items:center;flex-wrap:wrap;justify-content:flex-end;}
    .select{padding:9px 10px;border-radius:12px;border:1px solid var(--border);background:#fff;font-weight:900;font-size:13px;color:#374151;outline:none;}
    .select:focus{border-color:var(--orange);box-shadow:0 0 0 4px rgba(255,138,0,.16)}
    .empty{padding:26px 16px;color:var(--muted);text-align:center;}
  </style>
</head>
<body>
  <div class="topbar">Saporsi Admin • Products</div>

  <div class="wrap">
    <div class="header">
      <div>
        <h1>Products</h1>
        <div class="meta">Total: <b><%= total %></b> • Page <b><%= page %></b>/<b><%= totalPages %></b></div>
      </div>
      <div class="actions">
        <a class="btn btn-primary" href="/admin/products/new">+ New Product</a>
        <a class="btn btn-ghost" href="/admin">Dashboard</a>
        <a class="btn btn-link" href="/auth/logout">Logout</a>
      </div>
    </div>

    <div class="card">
      <div class="toolbar">
        <div class="muted">Tip: price simpan integer IDR (contoh 15000)</div>
      </div>

      <% if (!rows || rows.length === 0) { %>
        <div class="empty">Belum ada product. Klik <b>New Product</b> untuk menambahkan.</div>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th style="width:90px;">ID</th>
              <th style="width:180px;">SKU</th>
              <th>Name</th>
              <th style="width:160px;">Price</th>
              <th style="width:150px;">Status</th>
              <th style="width:110px;">Action</th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach(function(p){ %>
              <tr>
                <td class="mono"><%= p.id %></td>
                <td class="mono"><b><%= p.sku %></b></td>
                <td>
                  <b><%= p.name %></b>
                  <div class="muted" style="margin-top:4px;">Updated: <%= p.updated_at_fmt %></div>
                </td>
                <td class="mono">Rp <%= p.price_fmt %></td>
                <td>
                  <% if (p.is_active) { %>
                    <span class="badge on"><span class="dot"></span> Active</span>
                  <% } else { %>
                    <span class="badge off"><span class="dot"></span> Inactive</span>
                  <% } %>
                </td>
                <td><a class="btn btn-ghost" style="padding:8px 10px;" href="/admin/products/<%= p.id %>/edit">Edit</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>

      <div class="footer">
        <div class="muted">
          <% const start = (page - 1) * limit + 1; %>
          <% const end = (page - 1) * limit + (rows ? rows.length : 0); %>
          <% if (rows && rows.length) { %>
            Showing <b><%= start %></b>–<b><%= end %></b> of <b><%= total %></b>
          <% } else { %>
            Showing 0 of <b><%= total %></b>
          <% } %>
        </div>

        <div class="pager">
          <label class="muted">Limit</label>
          <select class="select" onchange="location.href='/admin/products?page=1&limit=' + this.value;">
            <option value="10" <%= limit === 10 ? 'selected' : '' %>>10</option>
            <option value="20" <%= limit === 20 ? 'selected' : '' %>>20</option>
            <option value="50" <%= limit === 50 ? 'selected' : '' %>>50</option>
          </select>

          <% const prev = page > 1 ? page - 1 : 1; %>
          <% const next = page < totalPages ? page + 1 : totalPages; %>

          <% if (page > 1) { %>
            <a class="btn btn-primary" href="/admin/products?page=<%= prev %>&limit=<%= limit %>">Prev</a>
          <% } %>
          <% if (page < totalPages) { %>
            <a class="btn btn-primary" href="/admin/products?page=<%= next %>&limit=<%= limit %>">Next</a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
