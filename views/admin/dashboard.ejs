<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <style>
    .dash-head { display:flex; justify-content:space-between; gap:12px; align-items:end; flex-wrap:wrap; margin-bottom:14px; }
    .dash-head h2 { margin:0; font-size:24px; }
    .muted { color:#7a6f67; font-size:13px; }
    .filter { display:flex; gap:8px; align-items:end; flex-wrap:wrap; }
    .field { display:grid; gap:5px; }
    .field label { font-size:12px; color:#7a6f67; }
    .field input { min-width:160px; padding:9px 10px; border-radius:10px; border:1px solid #eadfd2; }
    .btn { border:0; border-radius:10px; padding:10px 12px; color:#fff; font-weight:700; cursor:pointer; background:linear-gradient(135deg,#8b5cf6,#ec4899); }
    .stats { display:grid; grid-template-columns:repeat(3, minmax(180px, 1fr)); gap:10px; margin-bottom:14px; }
    .stats-owner { display:grid; grid-template-columns:repeat(6, minmax(150px, 1fr)); gap:10px; margin-bottom:14px; }
    .stat { border:1px solid #eadfd2; border-radius:14px; background:#fffaf4; padding:14px; }
    .stat b { display:block; font-size:12px; color:#7a6f67; margin-bottom:6px; text-transform:uppercase; letter-spacing:.04em; }
    .stat h3 { margin:0; font-size:28px; line-height:1.2; color:#2b2420; }
    @media (max-width: 1100px) { .stats-owner{grid-template-columns:repeat(3, minmax(140px, 1fr));} }
    @media (max-width: 900px) { .stats, .stats-owner{grid-template-columns:1fr;} }
  </style>
</head>
<body>
  <section class="dash-head">
    <div>
      <h2>Dashboard Overview</h2>
      <div class="muted">Welcome back, <%= user.role %>. Ringkasan performa berdasarkan rentang tanggal.</div>
    </div>
    <form method="GET" action="/admin" class="filter">
      <div class="field">
        <label>Dari tanggal</label>
        <input type="date" name="date_from" value="<%= dateFrom %>" />
      </div>
      <div class="field">
        <label>Sampai tanggal</label>
        <input type="date" name="date_to" value="<%= dateTo %>" />
      </div>
      <button class="btn" type="submit">Apply</button>
    </form>
  </section>

  <section class="stats">
    <article class="stat">
      <b>Turnover</b>
      <h3>Rp <%= summary.turnoverFmt %></h3>
    </article>
    <article class="stat">
      <b>Profit</b>
      <h3>Rp <%= summary.profitFmt %></h3>
    </article>
    <article class="stat">
      <b>Transactions</b>
      <h3><%= summary.transactions %></h3>
    </article>
  </section>

  <section class="stats-owner">
    <article class="stat">
      <b>Merchants</b>
      <h3><%= ownerStats.merchants %></h3>
    </article>
    <article class="stat">
      <b>Locations</b>
      <h3><%= ownerStats.locations %></h3>
    </article>
    <article class="stat">
      <b>Machines</b>
      <h3><%= ownerStats.machines %></h3>
    </article>
    <article class="stat">
      <b>Products</b>
      <h3><%= ownerStats.products %></h3>
    </article>
    <article class="stat">
      <b>Slots Total</b>
      <h3><%= ownerStats.slotsTotal %></h3>
    </article>
    <article class="stat">
      <b>Slots Active</b>
      <h3><%= ownerStats.slotsActive %></h3>
    </article>
  </section>

</body>
</html>
