<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <style>
    :root{--bg:#fff6ec;--card:#fff;--text:#111827;--muted:#6b7280;--border:#e5e7eb;--orange:#ff8a00;--orange2:#ffb866;--shadow:0 18px 45px rgba(0,0,0,.08);}
    *{box-sizing:border-box}
    body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;background:var(--bg);color:var(--text)}
    .top{background:linear-gradient(135deg,var(--orange),var(--orange2));color:#fff;padding:18px 22px;font-weight:900}
    .wrap{max-width:1100px;margin:0 auto;padding:22px}
    .hero{background:#fff;border:1px solid var(--border);border-radius:18px;padding:18px;box-shadow:var(--shadow);display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap}
    .hero h1{margin:0;font-size:22px}
    .muted{color:var(--muted);font-size:13px}
    .logout{display:inline-flex;text-decoration:none;padding:10px 12px;border:1px solid var(--border);border-radius:12px;background:#fff;color:#7c2d12;font-weight:900}
    .grid{margin-top:16px;display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px}
    .card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px;box-shadow:var(--shadow);text-decoration:none;color:inherit;transition:.15s}
    .card:hover{transform:translateY(-2px);background:#fffaf4}
    .card h3{margin:0 0 6px;font-size:16px}
    .card p{margin:0;color:var(--muted);font-size:13px;line-height:1.6}
  </style>
</head>
<body>
  <div class="top">Saporsi Core • Admin Console</div>
  <div class="wrap">
    <section class="hero">
      <div>
        <h1>Welcome back, <%= user.role %></h1>
        <div class="muted">Pilih modul untuk mengelola operasional vending.</div>
      </div>
      <a class="logout" href="/auth/logout">Logout</a>
    </section>

    <section class="grid">
      <a class="card" href="/admin/merchants"><h3>Merchants</h3><p>Kelola partner merchant dan status aktif.</p></a>
      <a class="card" href="/admin/locations"><h3>Locations</h3><p>Kelola titik lokasi tempat machine ditempatkan.</p></a>
      <a class="card" href="/admin/machines"><h3>Machines</h3><p>Kelola data machine dan assignment lokasinya.</p></a>
      <a class="card" href="/admin/products"><h3>Products</h3><p>Kelola master produk dan harga default.</p></a>
      <a class="card" href="/admin/slots"><h3>Slots</h3><p>Atur produk, harga final, dan stok per slot.</p></a>
      <a class="card" href="/admin/orders"><h3>Orders</h3><p>Pantau status pembayaran dan detail transaksi.</p></a>
    </section>
  </div>
</body>
</html>
