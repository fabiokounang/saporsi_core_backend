<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title %></title>
  <style>
    :root{
      --bg:#fff6ec;--card:#fff;--text:#111827;--muted:#6b7280;--border:#e5e7eb;
      --orange:#ff8a00;--orange2:#ffb866;--shadow:0 18px 45px rgba(0,0,0,.08);--radius:16px;
      --danger-bg:#fef2f2;--danger-border:#fecaca;--danger-text:#991b1b;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;background:var(--bg);color:var(--text);}
    .topbar{background:linear-gradient(135deg,var(--orange),var(--orange2));color:#fff;padding:16px 22px;font-weight:900;}
    .wrap{max-width:760px;margin:0 auto;padding:22px;}
    .card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);padding:18px;}
    h1{margin:0 0 10px;font-size:22px}
    .muted{color:var(--muted);font-size:13px}
    label{display:block;margin:14px 0 6px;font-weight:900;font-size:13px;color:#374151}
    input,select{
      width:100%;padding:12px 14px;border:1px solid var(--border);border-radius:12px;
      font-size:14px;outline:none;background:#fff;
    }
    .date-wrap{position:relative}
    .date-wrap input[type="date"]{
      padding-right:46px;
      -webkit-appearance:none;
      appearance:none;
    }
    .date-wrap input[type="date"]::-webkit-calendar-picker-indicator{
      opacity:0;
      position:absolute;
      right:0;
      top:0;
      width:40px;
      height:100%;
      cursor:pointer;
    }
    .date-btn{
      position:absolute;right:10px;top:50%;transform:translateY(-50%);
      width:28px;height:28px;border-radius:8px;border:1px solid #fed7aa;background:#fff7ed;color:#9a3412;
      display:inline-flex;align-items:center;justify-content:center;cursor:pointer;font-size:15px;line-height:1;
      z-index:2;
    }
    .date-btn:hover{background:#ffedd5}
    .date-btn:focus{outline:none;box-shadow:0 0 0 3px rgba(255,138,0,.2)}
    .segment{display:flex;gap:8px;flex-wrap:wrap}
    .segment .opt{
      display:inline-flex;align-items:center;gap:6px;padding:8px 10px;border-radius:999px;
      border:1px solid var(--border);background:#fff;font-size:12px;font-weight:800;color:#374151;cursor:pointer;
    }
    .segment .opt input{width:auto;padding:0;margin:0}
    .readonly{background:#f8fafc !important;color:#4b5563}
    input:focus,select:focus{border-color:var(--orange);box-shadow:0 0 0 4px rgba(255,138,0,.16)}
    .row{display:flex;gap:12px;flex-wrap:wrap;margin-top:16px;align-items:center;}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:11px 14px;border-radius:12px;font-weight:900;font-size:13px;border:1px solid transparent;cursor:pointer;text-decoration:none}
    .btn-primary{background:linear-gradient(135deg,var(--orange),var(--orange2));color:#fff;box-shadow:0 14px 28px rgba(255,138,0,.28)}
    .btn-secondary{background:#fff;border:1px solid var(--border);color:#7c2d12}
    .btn-secondary:hover{background:#fff7ed}
    .alert{background:var(--danger-bg);border:1px solid var(--danger-border);color:var(--danger-text);padding:12px 12px;border-radius:12px;margin-bottom:12px;font-size:13px}
    .hint{margin-top:6px;color:var(--muted);font-size:12.5px}
    .idpill{display:inline-flex;align-items:center;gap:8px;padding:6px 10px;border-radius:999px;border:1px solid var(--border);background:#fff;color:#374151;font-weight:900;font-size:12px;}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    @media (max-width:640px){.grid2{grid-template-columns:1fr}}
  </style>
</head>
<body>
  <div class="topbar">Saporsi Admin • Edit Machine</div>

  <div class="wrap">
    <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
      <div>
        <h1>Edit Machine</h1>
        <div class="muted">Update code, nama, lokasi, dan status.</div>
      </div>
      <div class="idpill">Machine ID: <%= machine.id %></div>
    </div>

    <div style="height:14px;"></div>

    <div class="card">
      <% if (error) { %>
        <div class="alert"><b>Gagal:</b> <%= error %></div>
      <% } %>

      <form method="POST" action="/admin/machines/<%= machine.id %>">
        <label for="code">Machine Code (unique)</label>
        <input id="code" name="code" value="<%= value?.code || '' %>" required />

        <label for="name">Machine Name (optional)</label>
        <input id="name" name="name" value="<%= value?.name || '' %>" />

        <label for="category">Kategori</label>
        <input id="category" name="category" value="<%= value?.category || '' %>" placeholder="contoh: Dispenser" maxlength="128" />

        <label for="purchase_date">Tanggal pembelian</label>
        <div class="date-wrap">
          <input id="purchase_date" type="date" name="purchase_date" value="<%= value?.purchase_date || '' %>" />
          <button type="button" class="date-btn js-date-btn" data-target="purchase_date" aria-label="Kalender tanggal pembelian" title="Pilih tanggal">📅</button>
        </div>

        <label for="manufactured_at">Tanggal dibuat pabrik</label>
        <div class="date-wrap">
          <input id="manufactured_at" type="date" name="manufactured_at" value="<%= value?.manufactured_at || '' %>" />
          <button type="button" class="date-btn js-date-btn" data-target="manufactured_at" aria-label="Buka kalender tanggal dibuat pabrik" title="Pilih tanggal">📅</button>
        </div>
        <div class="hint">Umur (pabrik) di daftar dihitung dari tanggal ini.</div>

        <label for="installed_at">Tanggal dipasang</label>
        <div class="date-wrap">
          <input id="installed_at" type="date" name="installed_at" value="<%= value?.installed_at || '' %>" />
          <button type="button" class="date-btn js-date-btn" data-target="installed_at" aria-label="Buka kalender tanggal dipasang" title="Pilih tanggal">📅</button>
        </div>
        <div class="hint">Perkiraan umur sampai hari ini: <b>Pabrik</b> <%= lifespan_since_factory_preview %> · <b>Pasang</b> <%= lifespan_since_install_preview %>.</div>

        <label for="last_maintenance_at">Last MT (maintenance terakhir)</label>
        <div class="date-wrap">
          <input id="last_maintenance_at" type="date" name="last_maintenance_at" value="<%= value?.last_maintenance_at || '' %>" />
          <button type="button" class="date-btn js-date-btn" data-target="last_maintenance_at" aria-label="Kalender last MT" title="Pilih tanggal">📅</button>
        </div>

        <label for="maintenance_at">Next MT (jadwal maintenance berikutnya)</label>
        <div class="segment">
          <label class="opt">
            <input type="radio" name="maintenance_mode" value="auto" <%= (value?.maintenance_mode || 'auto') === 'auto' ? 'checked' : '' %> />
            Auto (+3 bulan dari tanggal pabrik)
          </label>
          <label class="opt">
            <input type="radio" name="maintenance_mode" value="manual" <%= (value?.maintenance_mode || 'auto') === 'manual' ? 'checked' : '' %> />
            Manual
          </label>
        </div>
        <div class="date-wrap" style="margin-top:8px;">
          <input id="maintenance_at" type="date" name="maintenance_at" value="<%= value?.maintenance_at || '' %>" />
          <button type="button" class="date-btn js-date-btn" data-target="maintenance_at" aria-label="Kalender next MT" title="Pilih tanggal">📅</button>
        </div>
        <div class="hint">Mode auto mengisi next MT = 3 bulan setelah tanggal pabrik.</div>

        <div class="grid2">
          <div>
            <label for="total_runtime_hours">Total runtime (jam)</label>
            <input id="total_runtime_hours" name="total_runtime_hours" inputmode="decimal" value="<%= value?.total_runtime_hours || '' %>" placeholder="0" />
          </div>
          <div>
            <label for="total_downtime_hours">Total downtime (jam)</label>
            <input id="total_downtime_hours" name="total_downtime_hours" inputmode="decimal" value="<%= value?.total_downtime_hours || '' %>" placeholder="0" />
          </div>
        </div>

        <label for="location_id">Location</label>
        <select id="location_id" name="location_id" required>
          <option value="">-- pilih lokasi --</option>
          <% (locations || []).forEach(function(l){ %>
            <option value="<%= l.id %>"
              <%= String(value?.location_id || '') === String(l.id) ? 'selected' : '' %>>
              <%= l.parent_name ? (l.parent_name + ' › ' + l.name) : l.name %><%= l.is_active ? '' : ' (inactive)' %>
            </option>
          <% }) %>
        </select>
        <div class="hint">Kamu masih bisa pilih lokasi inactive (untuk data historis), tapi idealnya aktif.</div>

        <label for="is_active">Status</label>
        <select id="is_active" name="is_active">
          <option value="1" <%= (value?.is_active ?? 1) ? 'selected' : '' %>>Active</option>
          <option value="0" <%= (value?.is_active ?? 1) ? '' : 'selected' %>>Inactive</option>
        </select>

        <div class="row">
          <button class="btn btn-primary" type="submit">Save Changes</button>
          <a class="btn btn-secondary" href="/admin/machines/<%= machine.id %>/detail">Detail</a>
          <a class="btn btn-secondary" href="/admin/machines">Back</a>
          <a class="btn btn-secondary" href="/admin">Dashboard</a>
        </div>
      </form>
    </div>
  </div>
  <script src="/public/js/machine-date-picker.js" defer></script>
</body>
</html>
